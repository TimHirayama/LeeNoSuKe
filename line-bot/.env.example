# ==========================================
# 🚀 商業化公版機器人設定檔 (SaaS Boilerplate)
# 只要填滿這個檔案，並修改 src/prompts/ 裡的語氣，
# 就能輕鬆發布一隻全新的客製化 LINE 機器人給客戶！
# ==========================================

# 1. 基礎通訊設定 (LINE API)
LINE_CHANNEL_ACCESS_TOKEN="請填寫你的LINE官方帳號Token"
LINE_CHANNEL_SECRET="請填寫你的LINE官方帳號Secret"

# 2. 驅動核心引擎 (Google API)
GEMINI_API_KEY="請填入Google AI Studio申請的 Gemini API Key"
GOOGLE_APPLICATION_CREDENTIALS="/etc/secrets/google-key.json" # Google日曆金鑰路徑
CALENDAR_ID="primary"  # 預設為 primary (主人的主日曆)

# 3. 身分與權限控制 (Authorization)
# 填入客戶/老闆個人的 LINE User ID (必定以 U 開頭)，唯有此人能觸發私密功能，其他人會觸發發言人 RAG 機制。
ADMIN_USER_ID="Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 4. 機器人人設包裝 (Persona)
# 當有人在群組呼叫時，可以辨識的名字 (多個可用逗號分隔)
BOT_ALIASES="狸之助,小幫手" 
# 此機器人自稱的身分/品種 (例如：河狸、AI秘書、傲嬌店長)，將自動注射進 Prompt 裡。
BOT_PERSONA="河狸"

# 5. 付費模組開關 (Feature Flags)
# 控制哪些模組被啟用。若未填寫皆預設為 true (全部開放)。
FEATURE_PRIVATE_ASSISTANT=true    # 行事曆與個人特助功能 (主人專屬)
FEATURE_SPOKESPERSON=true         # RAG 代理發言人功能 (對待非主人使用者)
FEATURE_TRANSLATOR=true           # 群組攔截中日互譯官 (透過密碼授權開啟)
